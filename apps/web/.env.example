# Base URL of the epg-cache service
PUBLIC_EPG_CACHE_URL=http://localhost:3000

# TVHeadend credentials used only by server-side live stream resolver/proxy
TVH_URL=http://localhost:9981
TVH_USERNAME=admin
TVH_PASSWORD=secret

# Optional: transport -> profile mapping used when `transport` is set and no explicit `profile` is provided.
# Example: {"hls":"webtv-h264-aac-mpegts","pass":"pass"}
TVH_STREAM_PROFILE_MAP=

# Optional: default transport applied when request does not provide transport/profile
# Example: hls
TVH_STREAM_DEFAULT_TRANSPORT=

# Optional: stream path template (default: /stream/channel/{channelUuid})
TVH_STREAM_PATH_TEMPLATE=/stream/channel/{channelUuid}
