{
  "name": "@tvh-guide/hls-proxy",
  "version": "0.1.0",
  "description": "HLS proxy and ffmpeg orchestration service for TVHeadend live channels",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "tvheadend",
    "hls",
    "ffmpeg",
    "proxy",
    "streaming"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.0.0",
    "@tvh-guide/tvheadend-client": "workspace:*",
    "hono": "^4.12.2",
    "pino": "^9.14.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "volta": {
    "node": "24.13.1"
  }
}
