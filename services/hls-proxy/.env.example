# TVHeadend connection (required)
TVH_URL=http://tvheadend:9981
TVH_USERNAME=admin
TVH_PASSWORD=

# TVHeadend stream profile name used for upstream input (required)
HLS_TVH_PROFILE=webtv-h264-aac-mpegts

# Service settings (optional)
HLS_HTTP_PORT=3010
HLS_INACTIVITY_GRACE_SECONDS=90
HLS_SWEEP_INTERVAL_SECONDS=10
HLS_SEGMENT_SECONDS=4
HLS_PLAYLIST_SIZE=8
HLS_DELETE_THRESHOLD=2
HLS_STARTUP_TIMEOUT_MS=15000
HLS_ASSET_WAIT_TIMEOUT_MS=6000
HLS_OUTPUT_ROOT=./data/hls-proxy
HLS_TVH_STREAM_PATH_TEMPLATE=/stream/channel/{channelUuid}
HLS_FFMPEG_BIN=ffmpeg
HLS_LOG_LEVEL=info
HLS_MAX_CONCURRENT_TRANSCODINGS=6
